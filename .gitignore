# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# ignore the datasets from uploading to GitHub. Archived in Zenodo and available on request.
simulations/complete_data/datasets/*.RData
simulations/missing_outcomes/miss_datasets/

# ignore all .bash files from repository
simulations/complete_data/scripts/**/*.bash

# ignore complete-data manifests/checkpoints in procedure folders
simulations/complete_data/complete_data_results/single_stage/input_manifest.csv
simulations/complete_data/complete_data_results/two_stage/input_manifest.csv
simulations/complete_data/complete_data_results/single_stage_cf/input_manifest.csv
simulations/complete_data/complete_data_results/two_stage_cf/input_manifest.csv
simulations/complete_data/complete_data_results/single_stage/checkpoint.csv
simulations/complete_data/complete_data_results/two_stage/checkpoint.csv
simulations/complete_data/complete_data_results/single_stage_cf/checkpoint.csv
simulations/complete_data/complete_data_results/two_stage_cf/checkpoint.csv
simulations/complete_data/complete_data_results/single_stage/single_stage_input_manifest.csv
simulations/complete_data/complete_data_results/two_stage/two_stage_input_manifest.csv
simulations/complete_data/complete_data_results/single_stage/single_stage_checkpoint.csv
simulations/complete_data/complete_data_results/two_stage/two_stage_checkpoint.csv

# local sanity checks
tests/sanity/

# renv artifacts
renv/library/
renv/staging/
renv/python/
renv/.cache/

# Hide local logs
logs/
logs/missing_outcomes/

# one-off reconciliation helper for legacy missing-outcomes outputs
simulations/missing_outcomes/miss_scripts/reconcile_missing_outputs.R

.positai

.DS_Store
